#!/bin/sh
# Pre-push hook: run CLI + desktop app build and tests before allowing push to main.
# Matches the checks in .github/workflows/release.yml.

REMOTE="$1"
URL="$2"

# Only check on pushes to origin/upstream
if [ "$REMOTE" != "origin" ] && [ "$REMOTE" != "upstream" ]; then
  exit 0
fi

# Detect which branch is being pushed
ZERO_COMMIT="0000000000000000000000000000000000000000"
while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  # Only check main/master branch pushes
  case "$REMOTE_REF" in
    refs/heads/main|refs/heads/master)
      ;;
    *)
      continue
      ;;
  esac

  echo ""
  echo "=========================================="
  echo "  pre-push: CLI build + tests"
  echo "=========================================="

  echo "  -> bun run build"
  (cd cli && bun run build 2>&1)
  BUILD_EXIT=$?
  if [ $BUILD_EXIT -ne 0 ]; then
    echo ""
    echo "FAIL: CLI build failed (exit $BUILD_EXIT). Push rejected."
    exit 1
  fi
  echo "  -> CLI build OK"

  echo "  -> bun test"
  (cd cli && bun test 2>&1)
  TEST_EXIT=$?
  if [ $TEST_EXIT -ne 0 ]; then
    echo ""
    echo "FAIL: CLI tests failed (exit $TEST_EXIT). Push rejected."
    exit 1
  fi
  echo "  -> CLI tests OK"

  echo ""
  echo "=========================================="
  echo "  pre-push: desktop app build + tests"
  echo "=========================================="

  echo "  -> bun run build"
  (cd app && bun run build 2>&1)
  APP_BUILD_EXIT=$?
  if [ $APP_BUILD_EXIT -ne 0 ]; then
    echo ""
    echo "FAIL: Desktop app build failed (exit $APP_BUILD_EXIT). Push rejected."
    exit 1
  fi
  echo "  -> desktop build OK"

  echo "  -> bun run test"
  (cd app && bun run test 2>&1)
  APP_TEST_EXIT=$?
  if [ $APP_TEST_EXIT -ne 0 ]; then
    echo ""
    echo "FAIL: Desktop app tests failed (exit $APP_TEST_EXIT). Push rejected."
    exit 1
  fi
  echo "  -> desktop tests OK"

  echo "  -> bun run e2e"
  (cd app && bun run e2e 2>&1)
  APP_E2E_EXIT=$?
  if [ $APP_E2E_EXIT -ne 0 ]; then
    echo ""
    echo "FAIL: Desktop app end-to-end tests failed (exit $APP_E2E_EXIT). Push rejected."
    exit 1
  fi
  echo "  -> desktop end-to-end tests OK"

  echo ""
  echo "=========================================="
  echo "  pre-push: all checks passed"
  echo "=========================================="
done

exit 0
