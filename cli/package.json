{
  "name": "@kwonye/mcpx",
  "version": "0.1.3",
  "description": "HTTP-first MCP gateway and cross-client installer",
  "keywords": [
    "mcp",
    "cli",
    "gateway",
    "proxy",
    "agent",
    "ai",
    "gateway-proxy",
    "gateway-installer"
  ],
  "homepage": "https://github.com/kwonye/mcpx#readme",
  "bugs": {
    "url": "https://github.com/kwonye/mcpx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwonye/mcpx.git",
    "directory": "cli"
  },
  "license": "MIT",
  "author": "Will Kwon",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./dist/cli.js",
    "./core": "./dist/core/index.js",
    "./types": "./dist/types.js"
  },
  "bin": {
    "mcpx": "dist/cli.js"
  },
  "directories": {
    "test": "test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts --",
    "sync-version": "bun scripts/sync-version.mjs",
    "prebuild": "bun run sync-version",
    "build": "bun build src/cli.ts src/core/index.ts src/types.ts --outdir dist --target node --format esm --splitting --external commander --external hono --external zod --external \"@modelcontextprotocol/sdk\" --external \"@iarna/toml\" && tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationMap",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.1",
    "hono": "^4.12.14",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
